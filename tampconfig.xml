<?xml version="1.0"?>
<!--
  tampconfig_rubik_simple.xml  —  ktmpb TAMP configuration for the UR3 + Robotiq 85
  2x2 Rubik's cube scenario.

  This is the file ktmpb_full.launch.py consumes via tamp_config_filename:=.
  Run with (paths must be ABSOLUTE; everything referenced INSIDE this file must be
  RELATIVE to scenario_folder_path, except models):

    ros2 launch ktmpb_client ktmpb_full.launch.py \
      models_folder_path:=/usr/share/kautham/demos/models \
      scenario_folder_path:=<abs path to your rubik scenario folder> \
      tamp_config_filename:=tampconfig_rubik_simple.xml

  Output -> taskfile_tampconfig_rubik_simple.xml in this same folder.

  ============================ THINGS TO VERIFY ============================
  1. Indices in <Rob>/<Obj>/<Link> are ORDER indices in your Kautham problem
     file (ur3_rubik_kautham.xml). In that file the robot is the only <Robot>
     and rubik_cube is the LAST <Obstacle>. ktmpb uses the KauthamName strings
     here ("ur3_right", "rubik_cube") in the demos, so we use names; if your
     ktmpb version expects integer indices, replace with the 0-based index.
  2. Control vectors are NORMALIZED [0,1] Kautham controls in the order defined
     by right_ur3_with_gripper.cntr:
        [pan, lift, elbow, w1, w2, w3, gripper]
     These are copied verbatim from your generate_taskfile.py (already tuned).
  3. Tilt/Rotate are CUSTOM actions — they require TILT.py / ROTATE.py handlers
     and registration in ktmpb_python_interface.py (see notes at the bottom).
  =========================================================================
-->
<Config>

    <Problemfiles>
        <kautham    name="ur3_rubik_kautham.xml" />
        <pddldomain name="ff-domains/manipulation_domain.pddl" />
        <pddlproblem name="ff-domains/manipulation_problem.pddl" />
    </Problemfiles>

    <States>
        <Initial>
            <!-- Cube pose: X Y Z  vx vy vz theta  (axis-angle, like Kautham problem files) -->
            <Object name="RUBIK" kthname="rubik_cube"> 0.0 0.4 0.046 0.0 0.0 1.0 0.0 </Object>
            <!-- UR3 home configuration (normalized controls) -->
            <Robot name="UR3A" controlfile="controls/right_ur3_with_gripper.cntr">
                0.500 0.375 0.500 0.375 0.500 0.500 0.500
            </Robot>
        </Initial>
    </States>

    <Actions>

        <!-- ================= STANDARD pick / place ================= -->
        <Pick robot="UR3A" object="RUBIK" region="FIXTURE">
            <Rob> ur3_right </Rob>
            <Obj> rubik_cube </Obj>
            <Link> robotiq_85_base_link </Link>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <HomeControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.500 </HomeControls>
            <!-- GRASP config (gripper closed = 0.680). THIS is the one to retune in
                 the GUI if "no valid grasp configuration" appears (the PDF TODO). -->
            <GraspControls grasp="1"> 0.545 0.380 0.835 0.327 0.375 0.425 0.680 </GraspControls>
        </Pick>

        <Place robot="UR3A" object="RUBIK" region="FIXTURE">
            <Rob> ur3_right </Rob>
            <Obj> rubik_cube </Obj>
            <Link> robotiq_85_base_link </Link>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <HomeControls> 0.500 0.375 0.500 0.375 0.500 0.500 0.500 </HomeControls>
            <GraspControls grasp="1"> 0.545 0.380 0.835 0.327 0.375 0.425 0.680 </GraspControls>
        </Place>

        <!-- ================= CUSTOM: whole-cube tilts =================
             One <Tilt> entry per tilt action name in your PDDL plan.
             Your TILT.py:Tilt_read() decides which tags it reads. Here we expose
             the lift waypoint + the per-direction tilt peak (normalized controls). -->
        <Tilt robot="UR3A" object="RUBIK" axis="x" sign="pos">
            <Rob> ur3_right </Rob>
            <Obj> rubik_cube </Obj>
            <Link> robotiq_85_base_link </Link>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <GraspControls grasp="1"> 0.545 0.380 0.835 0.327 0.375 0.425 0.680 </GraspControls>
            <LiftControls> 0.545 0.300 0.650 0.280 0.375 0.425 0.680 </LiftControls>
            <PeakControls> 0.545 0.220 0.750 0.180 0.375 0.425 0.680 </PeakControls>
        </Tilt>
        <Tilt robot="UR3A" object="RUBIK" axis="x" sign="neg">
            <Rob> ur3_right </Rob> <Obj> rubik_cube </Obj> <Link> robotiq_85_base_link </Link>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <GraspControls grasp="1"> 0.545 0.380 0.835 0.327 0.375 0.425 0.680 </GraspControls>
            <LiftControls> 0.545 0.300 0.650 0.280 0.375 0.425 0.680 </LiftControls>
            <PeakControls> 0.545 0.440 0.600 0.430 0.375 0.425 0.680 </PeakControls>
        </Tilt>
        <Tilt robot="UR3A" object="RUBIK" axis="y" sign="pos">
            <Rob> ur3_right </Rob> <Obj> rubik_cube </Obj> <Link> robotiq_85_base_link </Link>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <GraspControls grasp="1"> 0.545 0.380 0.835 0.327 0.375 0.425 0.680 </GraspControls>
            <LiftControls> 0.545 0.300 0.650 0.280 0.375 0.425 0.680 </LiftControls>
            <PeakControls> 0.620 0.300 0.700 0.280 0.400 0.425 0.680 </PeakControls>
        </Tilt>
        <Tilt robot="UR3A" object="RUBIK" axis="y" sign="neg">
            <Rob> ur3_right </Rob> <Obj> rubik_cube </Obj> <Link> robotiq_85_base_link </Link>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <GraspControls grasp="1"> 0.545 0.380 0.835 0.327 0.375 0.425 0.680 </GraspControls>
            <LiftControls> 0.545 0.300 0.650 0.280 0.375 0.425 0.680 </LiftControls>
            <PeakControls> 0.470 0.300 0.700 0.280 0.350 0.425 0.680 </PeakControls>
        </Tilt>

        <!-- ================= CUSTOM: top-layer wrist turn =================
             Used for the execute_* / rotate_top_* plan actions. The handler
             twists wrist_3 from the grasp config to the CW or CCW peak while
             holding the cube, then releases. -->
        <Rotate robot="UR3A" object="RUBIK" dir="cw">
            <Rob> ur3_right </Rob> <Obj> rubik_cube </Obj> <Link> robotiq_85_base_link </Link>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <GraspControls grasp="1"> 0.545 0.380 0.835 0.327 0.375 0.425 0.680 </GraspControls>
            <PeakControls> 0.545 0.380 0.835 0.327 0.375 0.675 0.680 </PeakControls>
        </Rotate>
        <Rotate robot="UR3A" object="RUBIK" dir="ccw">
            <Rob> ur3_right </Rob> <Obj> rubik_cube </Obj> <Link> robotiq_85_base_link </Link>
            <Cont>controls/right_ur3_with_gripper.cntr</Cont>
            <GraspControls grasp="1"> 0.545 0.380 0.835 0.327 0.375 0.425 0.680 </GraspControls>
            <PeakControls> 0.545 0.380 0.835 0.327 0.375 0.175 0.680 </PeakControls>
        </Rotate>

    </Actions>
</Config>

<!--
  ============== HOW THE CUSTOM ACTIONS GET WIRED (summary) ==============
  For each new action MYACTION (Tilt, Rotate), per the tutorial:
    1. This tampconfig already declares it (above).
    2. PDDL domain/problem must define the matching action + predicates so the
       FF plan emits action names the manager can dispatch (your existing
       tilt_x_pos / execute_* actions).
    3. Code TILT.py and ROTATE.py next to PICK.py/PLACE.py, each with:
         def TILT(node, tilt, info, Line):     # performs the action via kautham_ros
         def Tilt_read(action_element):        # parses the <Tilt> tags above
       The body reuses the kautham service calls you already wrote in
       generate_taskfile.py's run() loop (plan_trajectory / kAttach / kDetach).
    4. Register them:  import MOVE, PICK, PLACE, TILT, ROTATE   in
       ktmpb_python_interface.py
    5. colcon build (with symlink-install) ; source install/setup.bash ; relaunch.
  =======================================================================
-->
