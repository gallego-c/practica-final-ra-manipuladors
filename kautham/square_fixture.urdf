<?xml version="1.0"?>
<robot name="square_fixture">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <!-- Real dimensions: 15.8 cm (X) x 15.8 cm (Y) x 13.5 cm tall -->
        <!-- XY: +5 cm por cada lado (+10 cm total por eje). Pocket 1.3 cm on top -->
        <box size="0.158 0.158 0.135" />
      </geometry>
      <material name="aluminum_gray">
        <color rgba="0.65 0.65 0.68 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.158 0.158 0.135" />
      </geometry>
    </collision>
  </link>
</robot>
