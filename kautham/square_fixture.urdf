<?xml version="1.0"?>
<robot name="square_fixture">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <!-- The fixture is slightly larger than the cube: 7 cm wide and 2 cm tall -->
        <box size="0.07 0.07 0.02" />
      </geometry>
      <!-- Metallic aluminum gray color -->
      <material name="aluminum_gray">
        <color rgba="0.65 0.65 0.68 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.07 0.07 0.02" />
      </geometry>
    </collision>
  </link>
</robot>
