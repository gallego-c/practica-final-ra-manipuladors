<?xml version="1.0"?>
<robot name="square_fixture">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <!-- Real dimensions: 5.8 cm wide x 5.8 cm deep x 15.5 cm tall -->
        <!-- Has a 1.3 cm deep pocket on top where the 5 cm cube rests -->
        <box size="0.058 0.058 0.155" />
      </geometry>
      <material name="aluminum_gray">
        <color rgba="0.65 0.65 0.68 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.058 0.058 0.155" />
      </geometry>
    </collision>
  </link>
</robot>
