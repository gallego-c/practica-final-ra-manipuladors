<?xml version="1.0"?>
<robot name="square_fixture">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <!-- Real dimensions: 5.8 cm (X) x 5.8 cm (Y) x 7.5 cm tall. Pocket 1.3 cm on top -->
        <box size="0.058 0.058 0.075" />
      </geometry>
      <material name="aluminum_gray">
        <color rgba="0.65 0.65 0.68 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.058 0.058 0.075" />
      </geometry>
    </collision>
  </link>
</robot>
