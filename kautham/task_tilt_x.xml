<?xml version="1.0"?>

<Problem name="OMPL_RRTConnect_custom_move">

	<Robot robot="./robots/robot_instances/UR_robotiq_85_gripper/ur3_robotiq_85_gripper.urdf.xacro" scale="1.0">
		<KauthamName name="ur3_right"/>
		<Home TH="3.14159265" WZ="1.0" WY="0.0" WX="0.0" Z="-0.07" Y="0.539" X="0.294" />
		<ViewLink name="robotiq_85_base_link"/>
	</Robot>

	<!-- Table base obstacle -->
	<Obstacle obstacle="./obstacles/chess/flat_chessboard/flat_chessboard.urdf" scale="1.3">
    <KauthamName name="table_base"/>
    <Home TH="1.570796327" WZ="1.0" WY="0.0" WX="0.0" Z="0.0" Y="0.0" X="0.0" />
</Obstacle>

	<!-- Square Fixture (holds the cube) -->
	<!-- Real dimensions: 5.8 x 5.8 x 7.5 cm. Center Z = 7.5/2 = 3.75 cm      -->
	<!-- XY = robot center (0.294, 0.539) + FK offset (-0.187, -0.399)          -->
	<Obstacle obstacle="square_fixture.urdf" scale="1.0">
		<KauthamName name="square_fixture"/>
		<Home TH="0.0" WZ="1.0" WY="0.0" WX="0.0" Z="0.0375" Y="0.140" X="0.107" />
	</Obstacle>

	<!-- 2x2 Rubik's Cube (5 x 5 x 5 cm) -->
	<!-- Sits in 1.3 cm pocket: Z = 7.5 - 1.3 + 2.5 = 8.7 cm from table       -->
	<Obstacle obstacle="rubik_cube_2x2.urdf" scale="1.0">
		<KauthamName name="rubik_cube"/>
		<Home TH="0.0" WZ="1.0" WY="0.0" WX="0.0" Z="0.087" Y="0.140" X="0.107" />
	</Obstacle>

	<!-- Controls config path -->
	<Controls robot="./controls/right_ur3_with_gripper.cntr"/>


	<Planner>
		<Parameters>
			<Name>omplRRTConnect</Name>
			<Parameter name="_Cspace Drawn">0</Parameter>
			<Parameter name="_Incremental (0/1)">0</Parameter>
			<Parameter name="_Max Planning Time">10</Parameter>
			<Parameter name="_Path Drawn (0/1)">1</Parameter>
			<Parameter name="_Simplify Solution">1</Parameter>
			<Parameter name="_Speed Factor">1</Parameter>
			<Parameter name="Range">0.5</Parameter>
		</Parameters>

		<Queries>
			<Query>
				<RobotControl name="ur3_right_shoulder_pan_joint"  init="0.567236111111111"  goal="0.6279444444444445"/>
				<RobotControl name="ur3_right_shoulder_lift_joint" init="0.4213888888888889" goal="0.4380416666666666"/>
				<RobotControl name="ur3_right_elbow_joint"         init="0.5854166666666667" goal="0.7506944444444444"/>
				<RobotControl name="ur3_right_wrist_1_joint"       init="0.40984722222222225" goal="0.3432222222222222"/>
				<RobotControl name="ur3_right_wrist_2_joint"       init="0.3749166666666667" goal="0.25366666666666665"/>
				<RobotControl name="ur3_right_wrist_3_joint"       init="0.571" goal="0.6519722222222223"/>
				<RobotControl name="ur3_right_gripper_joint"       init="0.500" goal="0.500"/>
			</Query>
		</Queries>

	</Planner>

</Problem>
